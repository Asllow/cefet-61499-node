{
  "device": "ESP32-A-Cerebro",
  "blocks": [
    { "id": "CLOCK", "type": "ECycle", "config": { "period_ms": 54 } },
    { "id": "SENSOR_EC11", "type": "EncoderInput", "config": { "gpio_a": 16, "gpio_b": 17, "ppr": 10000, "high_limit": 10000, "low_limit": -10000 } },
    { "id": "PID_LUA", "type": "Sandbox", "config": { "num_in": 1, "num_out": 1, "script_b64": "" } },
    { "id": "REDE_OUT", "type": "UdpPublisher", "config": { "target_ip": "192.168.137.61", "target_port": 5000 } },
    { "id": "MONITOR", "type": "SerialMonitor", "config": { "num_in": 2 } }
  ],
  "connections": [
    { "source": "CLOCK.EV_OUT", "target": "SENSOR_EC11.REQ" },
    { "source": "SENSOR_EC11.CNF", "target": "PID_LUA.REQ" },
    { "source": "PID_LUA.CNF", "target": "REDE_OUT.SEND" },
    { "source": "PID_LUA.CNF", "target": "MONITOR.REQ" },

    { "source": "SENSOR_EC11.ANGLE", "target": "PID_LUA.IN_0" },
    { "source": "PID_LUA.OUT_0", "target": "REDE_OUT.PAYLOAD_IN" },
    
    { "source": "SENSOR_EC11.ANGLE", "target": "MONITOR.IN_0" },
    { "source": "PID_LUA.OUT_0", "target": "MONITOR.IN_1" }
  ]
}